{
  "app": "mvn -e -q compile exec:java -Dexec.mainClass=com.cs2agg.infra.InfraApp",
  "watch": {
    "include": [
      "**"
    ],
    "exclude": [
      "README.md",
      "cdk.*.json",
      "src/test",
      "target"
    ]
  },
  "context": {
    "@aws-cdk/aws-apigateway:usagePlanKeyOrderInsensitiveId": true,
    "@aws-cdk/core:stackRelativeExports": true,
    "@aws-cdk/aws-rds:databaseInsensitiveClusterId": true,
    "@aws-cdk/aws-route53-targets:route53ApigatewayZoneIdFix": true,
    "@aws-cdk/aws-s3:createDefaultLoggingPolicy": true,
    "@aws-cdk/aws-sns-subscriptions:restrictSqsDescryption": true,
    "@aws-cdk/aws-apigateway:disableCloudWatchRole": true,
    "@aws-cdk/core:enablePartitionLiterals": true,
    "@aws-cdk/aws-ecs:disableLengthyClusterName": true,
    "@aws-cdk/aws-iam:minimizePolicies": true,
    "@aws-cdk/aws-iam:standardPowerUserBoundary": true,
    "@aws-cdk/aws-s3:serverAccessLogsUseBucketPolicy": true,
    "@aws-cdk/aws-route53-targets:globalvalRoute53ZoneIdFix": true,
    "@aws-cdk/aws-lambda:recognizeVersionProps": true,
    "@aws-cdk/aws-cloudfront:defaultSecurityPolicyTLSv1.2_2021": true,
    "@aws-cdk/core:checkSdkWriteSecurityPolicy": true,
    "@aws-cdk/aws-s3:defaultBucketNotificationsGoToQueue": true,
    "@aws-cdk/aws-ecs-patterns:useDefaultTaskRole": true
  }
}
